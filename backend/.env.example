MONGO_URL=mongodb+srv://lastlap_user:YOUR_PASSWORD@cluster0.example.mongodb.net/?retryWrites=true&w=majority
DB_NAME=lastlap_db
JWT_SECRET=replace-with-a-long-random-secret

CORS_ORIGINS=https://lastlap.fun,https://www.lastlap.fun
FRONTEND_PUBLIC_URL=https://lastlap.fun

ADMIN_EMAIL=admin@lastlap.com
ADMIN_PASSWORD=change-this-password

OTP_ENABLED=true
RESEND_API_KEY=
EMAIL_FROM=no-reply@lastlap.com

# X / Twitter login
# Add this exact production callback URL in the X Developer Portal:
# https://lastlap.fun/oauth/x/callback
# For local testing, also add:
# http://localhost:3000/oauth/x/callback

# Option A: OAuth 1.0a, using Consumer Key / Secret Key
# The Bearer Token from the X portal is app-level auth and is not used for user login.
X_CONSUMER_KEY=
X_CONSUMER_SECRET=

# Option B: OAuth 2.0, using Client ID / Client Secret
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=https://lastlap.fun/oauth/x/callback
X_OAUTH_SCOPES=tweet.read users.read like.read offline.access

# Twitterapi.io task verification
# Used by X follow/post claims. Repost and like claims use X OAuth 2.0.
TWITTERAPI_IO_API_KEY=
TWITTERAPI_IO_BASE_URL=https://api.twitterapi.io
TWITTERAPI_IO_TIMEOUT=15
TWITTERAPI_IO_MAX_PAGES=5
TWITTERAPI_IO_RETRIES=1
TWITTERAPI_IO_MIN_INTERVAL_SECONDS=0
X_LIKE_VERIFY_MAX_PAGES=5
X_REPOST_VERIFY_MAX_PAGES=5
