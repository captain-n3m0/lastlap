MONGO_URL=mongodb+srv://lastlap_user:YOUR_PASSWORD@cluster0.example.mongodb.net/?retryWrites=true&w=majority
DB_NAME=lastlap_db
JWT_SECRET=replace-with-a-long-random-secret

CORS_ORIGINS=http://localhost:3000
FRONTEND_PUBLIC_URL=http://localhost:3000

ADMIN_EMAIL=admin@lastlap.com
ADMIN_PASSWORD=change-this-password

OTP_ENABLED=true
RESEND_API_KEY=
EMAIL_FROM=no-reply@lastlap.com

# X / Twitter login
# Add this exact local callback URL in the X Developer Portal:
# http://localhost:3000/oauth/x/callback

# Option A: OAuth 1.0a, using Consumer Key / Secret Key
# The Bearer Token from the X portal is app-level auth and is not used for user login.
X_CONSUMER_KEY=
X_CONSUMER_SECRET=

# Option B: OAuth 2.0, using Client ID / Client Secret
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/x/callback
X_OAUTH_SCOPES=tweet.read users.read offline.access

# Twitterapi.io task verification
# Used by X task claims (follow/post/retweet checks). This is separate from X OAuth credentials.
TWITTERAPI_IO_API_KEY=
TWITTERAPI_IO_BASE_URL=https://api.twitterapi.io
TWITTERAPI_IO_MAX_PAGES=5
